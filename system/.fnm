# fnm (Fast Node Manager) initialization
# No caching — fnm is Rust-based (~2-5ms) and outputs session-specific paths

if (( $+commands[fnm] )); then
  eval "$(fnm env --use-on-cd --corepack-enabled --shell zsh)"
fi

# Helper function to upgrade global npm packages
fnm_upgrade() {
  fnm exec --using=$1 npm ls --global --json \
    | jq -r '.dependencies | to_entries[] | .key+"@"+.value.version' \
    | xargs npm i -g
}
